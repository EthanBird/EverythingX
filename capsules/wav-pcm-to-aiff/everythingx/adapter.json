{
  "adapter_id": "adapter:wav-pcm-to-aiff-static",
  "version": "0.1.0",
  "capsule": {
    "id": "capsule:wav-pcm-to-aiff",
    "version_requirement": "^0.1.0"
  },
  "protocol": {
    "name": "everythingx-adapter-protocol",
    "version_requirement": "0.1"
  },
  "transport": {
    "kind": "static-rust",
    "entrypoint": "WavPcmToAiffAdapter"
  },
  "capabilities": [
    {
      "capability_id": "capability:wav-pcm-to-aiff/pcm-exact/native-portable",
      "capsule_entrypoint": "convert",
      "strategy": "pcm-exact",
      "backend": "native-portable",
      "inputs": ["exfmt:audio:wav-pcm"],
      "outputs": ["exfmt:audio:aiff-pcm"],
      "preconditions": ["Input is a finite RIFF/WAVE carrying supported integer PCM"],
      "effects": ["Output is classic AIFF", "PCM signedness and byte order match AIFF"],
      "invariants": ["Sample rate", "Frame count", "Channel count", "PCM sample sequence"],
      "computability": "semantic_lossless",
      "loss": {
        "payload": "none",
        "temporal": "none",
        "structure": "normalized",
        "metadata": "bounded"
      },
      "default_options": {
        "metadata": "common-text",
        "strict_header_consistency": true,
        "buffer_size": 65536,
        "max_metadata_bytes": 1048576,
        "max_channels": 256
      },
      "defaults_are_runnable": true,
      "execution": {
        "streaming": false,
        "seek_required": false,
        "cost_evidence": []
      },
      "report_mapping": {
        "unknown_fields_are_preserved": true,
        "rules": [
          "PCM format and frame counts map to capsule_report",
          "input/output/audio byte counts map to measurements and capsule_report",
          "metadata preservation counts map to metadata loss",
          "the static Adapter buffers input to provide the Capsule's seekable reader"
        ]
      }
    }
  ]
}

