{
  "adapter_id": "adapter:aiff-pcm-to-wav-pcm-static", "version": "0.1.0",
  "capsule": {"id": "capsule:aiff-pcm-to-wav-pcm", "version_requirement": "^0.1.0"},
  "protocol": {"name": "everythingx-adapter-protocol", "version_requirement": "0.1"},
  "transport": {"kind": "static-rust", "entrypoint": "AiffPcmToWavPcmAdapter"},
  "capabilities": [{
    "capability_id": "capability:aiff-pcm-to-wav-pcm/pcm-exact/native-portable", "capsule_entrypoint": "convert", "strategy": "pcm-exact", "backend": "native-portable",
    "inputs": ["exfmt:audio:aiff-pcm"], "outputs": ["exfmt:audio:wav-pcm"],
    "preconditions": ["Input is finite classic AIFF carrying supported integer PCM and an exact integer sample rate"],
    "effects": ["Output is RIFF/WAVE integer PCM"], "invariants": ["Sample rate", "Frame count", "Channel count", "PCM sample sequence"],
    "computability": "semantic_lossless", "loss": {"payload": "none", "temporal": "none", "structure": "normalized", "metadata": "bounded"},
    "default_options": {"metadata": "common-text", "strict_header_consistency": true, "buffer_size": 65536, "max_metadata_bytes": 1048576, "max_channels": 256},
    "defaults_are_runnable": true, "execution": {"streaming": false, "seek_required": false, "cost_evidence": []},
    "report_mapping": {"unknown_fields_are_preserved": true, "rules": ["PCM facts and counts map to capsule_report", "metadata preservation maps to bounded loss", "static Adapter buffers protocol input for seek"]}
  }]
}
