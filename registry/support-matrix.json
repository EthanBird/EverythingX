        },
        "outputs": {
          "min": 1,
          "max": 1
        }
      },
      "standalone": true,
      "copy_out_tested": true,
      "capability_ids": [
        "capability:bmp-to-png/pixel-exact/native-portable"
      ]
    },
    {
      "capsule_id": "capsule:utf16-to-utf8",
      "version": "0.1.0",
      "crate": "utf16-to-utf8",
      "inputs": [
        "exfmt:text:utf-16"
      ],
      "outputs": [
        "exfmt:text:utf-8"
      ],
      "arity": {
        "inputs": {
          "min": 1,
          "max": 1
        },
        "outputs": {
          "min": 1,
          "max": 1
        }
