      "standalone": true,
      "copy_out_tested": true,
      "capability_ids": [
        "capability:utf16-to-utf8/replace-invalid/native-portable",
        "capability:utf16-to-utf8/strict/native-portable"
      ]
    },
    {
      "capsule_id": "capsule:wav-pcm-to-aiff",
      "version": "0.1.0",
      "crate": "wav-pcm-to-aiff",
      "inputs": [
        "exfmt:audio:wav-pcm"
      ],
      "outputs": [
        "exfmt:audio:aiff-pcm"
