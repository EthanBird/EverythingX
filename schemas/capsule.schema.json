{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://everythingx.dev/schema/capsule.schema.json",
  "title": "Standalone Conversion Capsule",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capsule_id", "version", "name", "summary", "license",
    "independence", "conversion", "api", "defaults", "strategies",
    "backends", "validation", "security"
  ],
  "properties": {
    "capsule_id": {"type": "string", "pattern": "^capsule:[a-z0-9._-]+$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"},
    "name": {"type": "string", "minLength": 1},
    "summary": {"type": "string", "minLength": 1},
    "license": {
      "type": "object",
      "required": ["expression", "file"],
      "properties": {
        "expression": {"type": "string"},
        "file": {"type": "string"},
        "commercial_authorization_required": {"type": "boolean"}
      }
    },
    "repository": {"type": ["string", "null"]},
    "independence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["standalone_cargo_build", "everythingx_optional", "external_path_dependencies"],
      "properties": {
        "standalone_cargo_build": {"const": true},
        "everythingx_optional": {"const": true},
        "external_path_dependencies": {"const": false},
        "copy_out_tested": {"type": "boolean"}
      }
    },
    "conversion": {
      "type": "object",
      "required": ["source", "target", "arity"],
      "properties": {
        "source": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "target": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "arity": {
          "type": "object",
          "required": ["inputs", "outputs"],
          "properties": {
            "inputs": {"$ref": "#/$defs/arity"},
            "outputs": {"$ref": "#/$defs/arity"}
          }
        },
        "scope": {"type": "array", "items": {"type": "string"}},
        "out_of_scope": {"type": "array", "items": {"type": "string"}}
      }
    },
    "api": {
      "type": "object",
      "required": ["language", "crate", "entrypoint", "owns_options_error_report"],
      "properties": {
        "language": {"const": "rust"},
        "crate": {"type": "string"},
        "entrypoint": {"type": "string"},
        "owns_options_error_report": {"const": true},
        "streaming": {"type": "boolean"},
        "seek_required": {"type": "boolean"}
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runnable", "strategy", "backend", "options"],
      "properties": {
        "runnable": {"const": true},
        "strategy": {"type": "string", "minLength": 1},
        "backend": {"type": "string", "minLength": 1},
        "options": {"type": "object"},
        "policy": {"enum": ["strict", "conservative", "balanced", "fast"]}
      }
    },
    "strategies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "guarantees"],
        "properties": {
          "id": {"type": "string"},
          "guarantees": {"type": "array", "items": {"type": "string"}},
          "tradeoffs": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "backends": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "tier", "default"],
        "properties": {
          "id": {"type": "string"},
          "tier": {"enum": ["native-portable", "native-simd", "system", "external", "hardware"]},
          "default": {"type": "boolean"},
          "dependencies": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "validation": {
      "type": "object",
      "required": ["specifications", "conformance", "differential", "properties", "regression", "fuzz", "benchmarks"],
      "properties": {
        "specifications": {"type": "array", "items": {"type": "string"}},
        "conformance": {"type": "array", "items": {"type": "string"}},
        "differential": {"type": "array", "items": {"type": "string"}},
        "properties": {"type": "array", "items": {"type": "string"}},
        "regression": {"type": "array", "items": {"type": "string"}},
        "fuzz": {"type": "array", "items": {"type": "string"}},
        "benchmarks": {"type": "array", "items": {"type": "string"}}
      }
    },
    "security": {
      "type": "object",
      "required": ["accepts_untrusted_input", "limits", "known_risks"],
      "properties": {
        "accepts_untrusted_input": {"type": "boolean"},
        "limits": {"type": "array", "items": {"type": "string"}},
        "known_risks": {"type": "array", "items": {"type": "string"}}
      }
    }
  },
  "$defs": {
    "arity": {
      "type": "object",
      "required": ["min", "max"],
      "properties": {
        "min": {"type": "integer", "minimum": 0},
        "max": {"type": ["integer", "null"], "minimum": 0}
      }
    }
  }
}
