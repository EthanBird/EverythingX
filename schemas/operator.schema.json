{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://everythingx.dev/schema/operator.schema.json",
  "title": "EverythingX atomic transformation operator",
  "type": "object",
  "required": [
    "operator_id", "contract_version", "implementation", "family", "layers",
    "arity", "inputs", "outputs", "preconditions", "effects", "invariants",
    "computability", "loss", "algebra", "execution", "dependencies", "security", "evidence"
  ],
  "additionalProperties": false,
  "properties": {
    "operator_id": {"type": "string", "pattern": "^exop:[a-z0-9._-]+:[a-z0-9._-]+:[0-9]+$"},
    "contract_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "implementation": {
      "type": "object",
      "required": ["language", "version", "backend_tier"],
      "properties": {
        "language": {"const": "rust"},
        "version": {"type": "string"},
        "backend_tier": {"enum": ["bytewise", "native", "system", "external"]}
      }
    },
    "family": {
      "enum": ["identify", "validate", "decode", "encode", "repackage", "remux", "transcode", "project", "extract", "split", "aggregate", "join", "normalize", "render", "infer", "encrypt", "decrypt"]
    },
    "layers": {
      "type": "array",
      "items": {"enum": ["carrier", "coding", "syntax", "model", "semantics", "behavior", "pragmatics"]},
      "minItems": 1
    },
    "arity": {
      "type": "object",
      "required": ["inputs", "outputs"],
      "properties": {
        "inputs": {"$ref": "#/$defs/aritySide"},
        "outputs": {"$ref": "#/$defs/aritySide"}
      }
    },
    "inputs": {"type": "array", "items": {"$ref": "#/$defs/port"}, "minItems": 1},
    "outputs": {"type": "array", "items": {"$ref": "#/$defs/port"}, "minItems": 1},
    "parameters": {"type": "array", "items": {"type": "object"}},
    "preconditions": {"type": "array", "items": {"type": "string"}},
    "effects": {"type": "array", "items": {"type": "string"}},
    "invariants": {"type": "array", "items": {"type": "string"}},
    "computability": {"enum": ["exact", "conditional_exact", "semantic_lossless", "controlled_lossy", "rendered", "inferential"]},
    "loss": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/lossEntry"}
    },
    "algebra": {
      "type": "object",
      "required": ["deterministic", "reversible", "idempotent"],
      "properties": {
        "deterministic": {"type": "boolean"},
        "reversible": {"type": "boolean"},
        "idempotent": {"type": "boolean"},
        "composition_rule": {"type": "string"}
      }
    },
    "execution": {
      "type": "object",
      "required": ["streaming", "seek_required", "random_access", "cost_model"],
      "properties": {
        "streaming": {"type": "boolean"},
        "seek_required": {"type": "boolean"},
        "random_access": {"type": "boolean"},
        "mmap_capable": {"type": "boolean"},
        "cost_model": {"type": "object"}
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "kind", "required"],
        "properties": {
          "name": {"type": "string"},
          "kind": {"enum": ["rust-crate", "system-library", "external-tool", "hardware", "schema", "font", "key", "model", "other"]},
          "required": {"type": "boolean"},
          "license": {"type": "string"}
        }
      }
    },
    "security": {
      "type": "object",
      "required": ["accepts_untrusted_input", "limits", "known_risks"],
      "properties": {
        "accepts_untrusted_input": {"type": "boolean"},
        "limits": {"type": "array", "items": {"type": "string"}},
        "known_risks": {"type": "array", "items": {"type": "string"}}
      }
    },
    "evidence": {
      "type": "object",
      "required": ["conformance", "roundtrip", "fuzz", "benchmarks"],
      "properties": {
        "conformance": {"type": "array", "items": {"type": "string"}},
        "roundtrip": {"type": "array", "items": {"type": "string"}},
        "fuzz": {"type": "array", "items": {"type": "string"}},
        "benchmarks": {"type": "array", "items": {"type": "string"}}
      }
    }
  },
  "$defs": {
    "aritySide": {
      "type": "object",
      "required": ["min"],
      "properties": {"min": {"type": "integer", "minimum": 0}, "max": {"type": ["integer", "null"], "minimum": 0}}
    },
    "port": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": {"type": "string"},
        "type": {"type": "string"},
        "capabilities": {"type": "array", "items": {"type": "string"}}
      }
    },
    "lossEntry": {
      "type": "object",
      "required": ["level"],
      "properties": {
        "level": {"enum": ["none", "normalized", "bounded", "unbounded", "unknown"]},
        "metric": {"type": "string"},
        "bound": {},
        "condition": {"type": "string"}
      }
    }
  }
}

